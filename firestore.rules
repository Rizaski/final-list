rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Require signed-in user (ensures data renders when deployed and user is logged in)
    function signedIn() {
      return request.auth != null;
    }

    // Limit write payload size for creates/updates. Deletes have request.resource == null — must not read .data or delete is denied.
    function sizeOk() {
      return request.resource == null || request.resource.data.size() <= 400;
    }

    // Pledged report shares can include a full voter list payload (potentially large).
    // We allow a higher limit than generic writes so the share document can be created.
    function pledgedShareSizeOk() {
      return request.resource == null || request.resource.data.size() <= 200000;
    }

    // Campaign config (Settings → Campaign)
    match /campaign/config {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Campaign users (Settings → User management; role: admin | candidate, candidateId for candidates)
    match /campaignUsers/{email} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && sizeOk();
    }

    // Voters list — read allowed for any signed-in user so list renders when deployed
    match /voters/{voterId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Agents (Settings → Agents)
    match /agents/{agentId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && sizeOk();
      allow delete: if signedIn();
    }

    // Candidates (Settings → Candidates)
    match /candidates/{docId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Monitors (e.g. zero-day / transport views)
    match /monitors/{token} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();

      match /voted/{voterId} {
        allow read: if signedIn();
        allow write: if signedIn() && sizeOk();
      }
    }

    // Voter lists (saved lists in main app)
    match /voterLists/{listId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Campaign events (Events module)
    match /events/{eventId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Zero Day transport trips (flights / speed boats)
    match /transportTrips/{tripId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Shared list view (candidate opens by link; doc id = share token)
    match /voterListShares/{token} {
      allow read: if true;
      allow create, update, delete: if signedIn() && sizeOk();
      match /status/{voterId} {
        allow read, write: if true;
      }
    }

    // Pledged voters report share (Reports → View pledged voters → Share link; doc id = token)
    match /pledgedReportShares/{token} {
      allow read: if true;
      allow create, update: if signedIn() && pledgedShareSizeOk();
    }

    // Deny any other path by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
