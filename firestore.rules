rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Require signed-in user (ensures data renders when deployed and user is logged in)
    function signedIn() {
      return request.auth != null;
    }

    function archiveDocFieldCountOk() {
      return request.resource == null || request.resource.data.size() <= 500;
    }

    // Limit write payload size for creates/updates. Deletes have request.resource == null — must not read .data or delete is denied.
    function sizeOk() {
      return request.resource == null || request.resource.data.size() <= 400;
    }

    // Pledged report shares can include a full voter list payload (potentially large).
    // We allow a higher limit than generic writes so the share document can be created.
    function pledgedShareSizeOk() {
      return request.resource == null || request.resource.data.size() <= 200000;
    }

    // Campaign config (Settings → Campaign)
    match /campaign/config {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Campaign users (Settings → User management; role: admin | candidate, candidateId for candidates)
    match /campaignUsers/{email} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && sizeOk();
    }

    // Voters list — read allowed for any signed-in user so list renders when deployed
    match /voters/{voterId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Agents (Settings → Agents)
    match /agents/{agentId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && sizeOk();
      allow delete: if signedIn();
    }

    // Candidates (Settings → Candidates)
    match /candidates/{docId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Monitors (Zero Day ballot box share links). Document id `token` is the secret in the URL;
    // unauthenticated clients must read/write only via that exact path (no collection listing).
    match /monitors/{token} {
      allow get: if true;
      allow list: if false;
      allow create, update: if signedIn() && sizeOk();
      allow delete: if signedIn();

      // Session state (open / paused / closed) for ballot monitors; link token is the credential.
      match /ballotSession/{docId} {
        allow read: if true;
        allow create, update: if sizeOk();
        allow delete: if signedIn();
      }

      match /voted/{voterId} {
        // Standalone ballot-box.html: anyone with the link can list/read/write marks (token is the credential).
        allow read: if true;
        allow create, update: if sizeOk();
        // Undo from the ballot link (delete) or staff signed in.
        allow delete: if true;
      }
    }

    // Voter lists (saved lists in main app)
    match /voterLists/{listId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Campaign events (Events module)
    match /events/{eventId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Zero Day transport trips (flights / speed boats)
    match /transportTrips/{tripId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Transportation route groupings (links multiple trips + route-level fields)
    match /transportRoutes/{routeId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && sizeOk();
      // Deletes have request.resource == null; keep explicit so removal always works for signed-in users.
      allow delete: if signedIn();
    }

    // Shared list view (candidate opens by link; doc id = share token)
    match /voterListShares/{token} {
      allow read: if true;
      allow create, update, delete: if signedIn() && sizeOk();
      match /status/{voterId} {
        allow read, write: if true;
      }
    }

    // Pledged voters report share (Reports → View pledged voters → Share link; doc id = token)
    match /pledgedReportShares/{token} {
      allow read: if true;
      allow create, update: if signedIn() && pledgedShareSizeOk();
      // Campaign archive wipe deletes these docs — was missing and caused PERMISSION_DENIED on wipe.
      allow delete: if signedIn();
    }

    // Event participants share (Events → Participants list; doc id = token)
    match /eventParticipantShares/{token} {
      allow read: if true;
      allow create, update, delete: if signedIn() && sizeOk();
      match /rows/{rowId} {
        // Anyone with the share link can add/edit/delete participant rows.
        allow read, write: if true;
      }
    }

    // Archived campaign snapshots (Settings → Campaign archive). Same bar as voters/agents: any signed-in user.
    // The UI only offers archive to admins; rules do not duplicate admin checks (avoids JWT/email/campaignUsers drift).
    match /campaignArchives/{archiveId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && archiveDocFieldCountOk();
      match /{document=**} {
        allow read: if signedIn();
        allow create, update, delete: if signedIn() && sizeOk();
      }
    }

    // Deny any other path by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}