rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Require signed-in user for all writes/reads
    function signedIn() {
      return request.auth != null;
    }

    // Optional: limit document size to reduce abuse (tune as needed)
    function sizeOk() {
      return request.resource.data.size() <= 400;
    }

    // Campaign config (Settings → Campaign)
    match /campaign/config {
      allow read, write: if signedIn() && sizeOk();
    }

    // Voters list
    match /voters/{voterId} {
      allow read, write: if signedIn() && sizeOk();
    }

    // Agents (Settings → Agents)
    match /agents/{agentId} {
      allow read, write: if signedIn() && sizeOk();
    }

    // Candidates (Settings → Candidates) — recently added
    match /candidates/{docId} {
      allow read, write: if signedIn() && sizeOk();
    }

    // Monitors (e.g. zero-day / transport views)
    match /monitors/{token} {
      allow read, write: if signedIn() && sizeOk();

      // Subcollection: voted per monitor token
      match /voted/{voterId} {
        allow read, write: if signedIn() && sizeOk();
      }
    }

    // Deny any other path by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
