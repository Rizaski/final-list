rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Require signed-in user (ensures data renders when deployed and user is logged in)
    function signedIn() {
      return request.auth != null;
    }

    // Limit write payload size to reduce abuse (read not restricted so lists render reliably)
    function sizeOk() {
      return request.resource.data.size() <= 400;
    }

    // Campaign config (Settings → Campaign)
    match /campaign/config {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Voters list — read allowed for any signed-in user so list renders when deployed
    match /voters/{voterId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Agents (Settings → Agents)
    match /agents/{agentId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Candidates (Settings → Candidates)
    match /candidates/{docId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Monitors (e.g. zero-day / transport views)
    match /monitors/{token} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();

      match /voted/{voterId} {
        allow read: if signedIn();
        allow write: if signedIn() && sizeOk();
      }
    }

    // Voter lists (saved lists in main app)
    match /voterLists/{listId} {
      allow read: if signedIn();
      allow write: if signedIn() && sizeOk();
    }

    // Shared list view (candidate opens by link; doc id = share token)
    match /voterListShares/{token} {
      allow read: if true;
      allow create, update, delete: if signedIn() && sizeOk();
      match /status/{voterId} {
        allow read, write: if true;
      }
    }

    // Deny any other path by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
